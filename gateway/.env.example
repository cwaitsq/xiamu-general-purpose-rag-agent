GATEWAY_MODE=qmd
RAG_KEFU_GATEWAY_API_KEY=replace-with-your-gateway-key

QMD_COLLECTION=foreign_trade_kb
QMD_SEARCH_MODE=search
QMD_TIMEOUT_SECONDS=60
QMD_NODE_BIN=node
QMD_CLI_PATH=
QMD_EMBED_MODEL=hf:Qwen/Qwen3-Embedding-0.6B-GGUF/Qwen3-Embedding-0.6B-Q8_0.gguf

RETRIEVAL_SCORE_THRESHOLD=0.35

LLM_ENABLED=true
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.2

APP_PORT=8765
APP_LOG_DIR=

# 下面这些是旧链路兼容配置，第一版默认不用
QDRANT_URL=http://127.0.0.1:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=rag_kb_chunks
QDRANT_DISTANCE=Cosine
QDRANT_TIMEOUT_SECONDS=30

EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
